# ═══════════════════════════════════════════════
#  InternAI — Environment Variables
#  Copy this to .env and fill in your values
# ═══════════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (change this in production!)
JWT_SECRET=internai_super_secret_key_2025

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Python AI microservice URL
# Run: python ai_model/app.py to start it
AI_SERVICE_URL=http://localhost:8000

# MongoDB (optional — uses in-memory store if not set)
# MONGODB_URI=mongodb://localhost:27017/internai

# Vercel environment variables
# Set these in Vercel Dashboard → Settings → Environment Variables
